# Banco de dados
DB_URL=jdbc:mysql://localhost:3306/retail_manager?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=seu_usuario
DB_PASSWORD=sua_senha

# JWT
JWT_SECRET=seu_jwt_secret_aqui

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=seu_token_aqui
MERCADO_PAGO_WEBHOOK_SECRET=seu_webhook_secret_aqui

# WhatsApp
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_TOKEN=seu_token_aqui

# Copie este arquivo para .env e preencha com seus valores reais
